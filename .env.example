# ─────────────────────────────────────────────────────────────────────────────
# Factory Careers — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Local development: run ./setup.sh — it generates .env automatically.
# Production / manual setup: copy this file to .env and fill in the values.
# Render: set the production variables on the web service.

# ─── Database ────────────────────────────────────────────────────────────────
# Used by docker-compose.yml to configure the Postgres container
DB_USER=factory_careers
DB_PASSWORD=change-me
DB_NAME=factory_careers

# PostgreSQL connection string (used by host tools: drizzle-kit, drizzle studio)
# docker-compose overrides this with the internal Docker hostname for the app.
# Render production: use the dedicated Supabase Postgres connection string.
DATABASE_URL=postgresql://factory_careers:change-me@localhost:5432/factory_careers

# ─── Authentication ──────────────────────────────────────────────────────────
# Min 32-character random string. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output

# Public URL of the app (used for session cookies and OAuth callbacks)
# Local: http://localhost:3001 | Production: https://careers.thefactoryhq.com
# Render production: set this to https://careers.thefactoryhq.com.
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated allowed origins (optional, for multi-domain setups)
# BETTER_AUTH_TRUSTED_ORIGINS=https://yourdomain.com

# ─── Object Storage (S3-compatible) ──────────────────────────────────────────
# Used by docker-compose.yml to configure the MinIO container
STORAGE_USER=factory_careers
STORAGE_PASSWORD=change-me

# App-level S3 config (used by host tools)
# docker-compose overrides S3_ENDPOINT with http://minio:9000 for the app container
# Local (MinIO): S3_ENDPOINT=http://localhost:9000, S3_FORCE_PATH_STYLE=true
# Supabase Storage S3: S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3,
# S3_FORCE_PATH_STYLE=true, S3_SKIP_BUCKET_POLICY=true
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=factory_careers
S3_SECRET_KEY=change-me
S3_BUCKET=factory-careers-documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_SKIP_BUCKET_POLICY=false
# Temporary Render scaffolds without Supabase can set this to true.
S3_SKIP_BUCKET_INIT=false

# Temporary Render scaffolds without Supabase can set this to true.
SKIP_RUNTIME_MIGRATIONS=false

# Durable recruiting task processing is opt-in per server process.
RECRUITING_WORKER_ENABLED=false

# Application email fan-out and delivery is opt-in per server process.
APPLICATION_NOTIFICATION_WORKER_ENABLED=false

# ─── SEO ─────────────────────────────────────────────────────────────────────
# Used by @nuxtjs/seo for sitemaps, canonical URLs, and OG tags
NUXT_PUBLIC_SITE_URL=http://localhost:3001
NUXT_PUBLIC_MARKETING_URL=https://thefactoryhq.com

# ─── Factory Access & Branding ───────────────────────────────────────────────
# Required for Docker builds while @caffeinebounce/email is installed from GitHub Packages.
# Use a read-only token with package read access; do not commit a real token.
# NODE_AUTH_TOKEN=ghp_read_packages_token
FACTORY_APP_NAME="Factory Careers"
FACTORY_ORG_NAME=Factory
FACTORY_ORG_SLUG=factory
FACTORY_ALLOWED_EMAIL_DOMAINS=thefactoryhq.com
# FACTORY_INITIAL_OWNER_EMAILS=founder@thefactoryhq.com
FACTORY_CAREERS_HIRING_INBOX=careers@thefactoryhq.com
FACTORY_CAREERS_CALENDAR_EMAIL=interviews@thefactoryhq.com
# FACTORY_CAREERS_CALENDAR_GROUP_ID=
FACTORY_DISABLE_PUBLIC_SIGNUP=true
FACTORY_ADMIN_SSO_ONLY=true
FACTORY_DISABLE_PUBLIC_ORG_CREATION=true
FACTORY_DISABLE_ANALYTICS_CONSENT_BANNER=true

# ─── Optional: Demo Mode ─────────────────────────────────────────────────────
# Set to an org slug to make that org read-only (blocks all mutations)
# Default seeded slug: reqcore-demo
# DEMO_ORG_SLUG=reqcore-demo

# ─── Optional: Trusted Proxy ─────────────────────────────────────────────────
# Requests use the socket peer for rate limiting by default.
#
# Dynamic managed ingress: enable only after verifying the platform overwrites
# X-Forwarded-For with the real client IP and the app cannot be reached directly.
# Enabling this on a directly reachable app allows clients to spoof their IP.
# TRUST_PROXY_HEADERS=true
#
# Static self-hosted proxy: keep TRUST_PROXY_HEADERS=false and set the exact
# socket-peer IP of the reverse proxy.
# TRUST_PROXY_HEADERS=false
# TRUSTED_PROXY_IP=

# ─── Optional: Rate Limit Tuning ─────────────────────────────────────────────
# Defaults are production-safe for a small ATS deployment. Raise only with
# explicit security/operations approval or in synthetic E2E test environments.
# API_GLOBAL_READ_RATE_LIMIT_MAX_REQUESTS=300
# API_GLOBAL_WRITE_RATE_LIMIT_MAX_REQUESTS=80
# API_AUTH_READ_RATE_LIMIT_MAX_REQUESTS=600
# API_AUTH_WRITE_RATE_LIMIT_MAX_REQUESTS=40
# BETTER_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# BETTER_AUTH_RATE_LIMIT_MAX_REQUESTS=100
# PUBLIC_APPLICATION_RATE_LIMIT_WINDOW_MS=900000
# PUBLIC_APPLICATION_RATE_LIMIT_MAX_REQUESTS=5

# ─── Optional: In-App Feedback ───────────────────────────────────────────────
# Fine-grained GitHub PAT with Issues:write scope
# GITHUB_FEEDBACK_TOKEN=ghp_...
# GitHub repo in "owner/repo" format
# GITHUB_FEEDBACK_REPO=theFactoryHQ/factory-careers

# ─── Optional: Analytics (PostHog) ──────────────────────────────────────────
# Privacy-focused product analytics & feature flags powered by PostHog.
# Get your project API key from https://posthog.com → Project settings.
# Users must accept the consent banner before any events are captured (GDPR).
# POSTHOG_PUBLIC_KEY=phc_...
# EU data center (default). Use https://us.i.posthog.com for US.
# POSTHOG_HOST=https://eu.i.posthog.com
# Personal API key with "Feature Flags: read" scope. When set, the server
# evaluates feature flags locally (no per-request HTTP round trip).
# POSTHOG_FEATURE_FLAGS_KEY=phx_...

# ─── Optional: Feature Flag Overrides (no PostHog required) ─────────────────
# Force any flag on or off without running PostHog. The full list of available
# flags lives in shared/feature-flags.ts. Variable name pattern:
#   FEATURE_FLAG_<UPPERCASE_KEY_WITH_UNDERSCORES>
# Accepted values: true / false / 1 / 0 / on / off (or a variant key for
# multivariate flags). Env overrides win over PostHog rollouts.
# Example — enable the new chatbot experience for everyone on this instance:
# FEATURE_FLAG_CHATBOT_EXPERIENCE=true
# Language support is disabled by default until localization is fully wired:
# FEATURE_FLAG_LANGUAGE_SUPPORT=true

# ─── Optional: OIDC SSO (Keycloak, Authentik, Authelia, Okta, etc.) ──────────
# Enable Single Sign-On via any OIDC-compliant identity provider.
# All three variables (CLIENT_ID, CLIENT_SECRET, DISCOVERY_URL) must be set to activate SSO.
# When configured, a "Sign in with SSO" button appears on the login page.

# OIDC client ID — from your identity provider's client/application settings
# OIDC_CLIENT_ID=factory-careers

# OIDC client secret — from your identity provider's credentials tab
# OIDC_CLIENT_SECRET=your-client-secret-here

# OIDC discovery URL — the .well-known/openid-configuration endpoint
# Keycloak:   https://keycloak.example.com/realms/YOUR_REALM/.well-known/openid-configuration
# Authentik:  https://authentik.example.com/application/o/YOUR_APP/.well-known/openid-configuration
# Authelia:   https://authelia.example.com/.well-known/openid-configuration
# Okta:       https://YOUR_ORG.okta.com/.well-known/openid-configuration
# Azure AD:   https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0/.well-known/openid-configuration
# OIDC_DISCOVERY_URL=https://keycloak.example.com/realms/master/.well-known/openid-configuration

# Display name for the SSO button (default: "SSO")
# OIDC_PROVIDER_NAME=Company SSO

# ─── Optional: Transactional Email ───────────────────────────────────────────
# Factory Careers logs emails to the console by default (safe for local dev).
# For production, configure one of the providers below.
# SMTP takes priority over Resend when SMTP_HOST is set.

# Option A: SMTP (recommended for self-hosted / enterprise setups)
# Supports any SMTP server: Postfix, Gmail, Exchange, Mailcow, Mailu, etc.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=careers@thefactoryhq.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Factory Careers <careers@thefactoryhq.com>"
# SMTP_SECURE=false   # true = implicit TLS (port 465), false = STARTTLS (port 587)

# Option B: Resend (recommended — shared with main thefactoryhq.com site for brand consistency)
# Use the *exact same RESEND_API_KEY* as the production thefactoryhq.com service (see render.yaml comments).
# EMAIL_FROM can also be set for full parity with main-site transactional mail.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL="Factory <hello@interviews.thefactoryhq.com>"
# EMAIL_FROM="Factory <hello@interviews.thefactoryhq.com>"

# ─── Optional: Calendar Integrations ─────────────────────────────────────────
# Microsoft Calendar is preferred for Factory. App-only mode avoids a user OAuth
# connect step and writes to mailbox calendars using Graph application access.
# FACTORY_CAREERS_CALENDAR_EMAIL should be a shared mailbox or user mailbox,
# not a Microsoft 365 group calendar.
# MICROSOFT_CALENDAR_AUTH_MODE=application
# Application permission: Calendars.ReadWrite (admin consent required)
# Recommended: scope Exchange app access to only the target mailboxes.
# MICROSOFT_CALENDAR_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CALENDAR_CLIENT_SECRET=your-microsoft-client-secret
# MICROSOFT_CALENDAR_TENANT_ID=your-tenant-id-or-domain
# FACTORY_CAREERS_CALENDAR_EMAIL=interviews@thefactoryhq.com
# FACTORY_CAREERS_CALENDAR_SYNC_SHARED=true
# FACTORY_CAREERS_CALENDAR_USER_EMAILS=recruiter1@thefactoryhq.com,recruiter2@thefactoryhq.com
# FACTORY_CAREERS_CALENDAR_SYNC_INTERVIEWERS=false
#
# Delegated mode remains available for Microsoft 365 group calendars. You can
# reuse the Microsoft app used for staff SSO if you add this redirect URI and
# delegated Graph permissions:
# Redirect URI: https://yourdomain.com/api/calendar/microsoft/callback
# Delegated permissions: User.Read, Calendars.ReadWrite, Group.ReadWrite.All, offline_access
# MICROSOFT_CALENDAR_AUTH_MODE=delegated
# MICROSOFT_CALENDAR_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CALENDAR_CLIENT_SECRET=your-microsoft-client-secret
# MICROSOFT_CALENDAR_TENANT_ID=your-tenant-id
# Optional if you want to skip group lookup by email:
# FACTORY_CAREERS_CALENDAR_GROUP_ID=your-microsoft-365-group-id

# Google Calendar remains supported upstream-style if configured.
# Redirect URI: https://yourdomain.com/api/calendar/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── Optional: Social Sign-In (Google, GitHub, Microsoft) ────────────────────
# Enable social login buttons on the sign-in and sign-up pages.
# Each provider requires both CLIENT_ID and CLIENT_SECRET to be set.
# When configured, "Continue with <Provider>" buttons appear on the auth pages.

# Google — Create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI: https://yourdomain.com/api/auth/callback/google
# AUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# GitHub — Create an OAuth App at https://github.com/settings/developers
# Redirect URI: https://yourdomain.com/api/auth/callback/github
# AUTH_GITHUB_CLIENT_ID=your-github-client-id
# AUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Microsoft — Register an app at https://portal.azure.com → App registrations
# Redirect URI: https://yourdomain.com/api/auth/callback/microsoft
# AUTH_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# AUTH_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# AUTH_MICROSOFT_TENANT_ID=common
