{
  "name": "factory-careers",
  "version": "1.4.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/careers-cli"
  ],
  "engines": {
    "node": ">=22.22.0 <23 || >=24.11.0 <25"
  },
  "scripts": {
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "start:railway": "npm run db:migrate && npm run db:seed && node .output/server/index.mjs",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "node scripts/install-git-hooks.mjs",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx server/scripts/seed.ts",
    "db:seed:factory": "npx tsx server/scripts/seed-factory.ts",
    "db:reseed": "npx tsx server/scripts/delete-demo-org.ts && npx tsx server/scripts/seed.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke:ai-candidate-review": "vitest run --config vitest.smoke.config.ts tests/smoke/ai-candidate-review-context-smoke.smoke.ts",
    "check:conventions": "bash scripts/check-conventions.sh",
    "preflight:pr-title": "node scripts/validate-current-pr-title.mjs",
    "preflight:pr": "node scripts/run-pr-validation-preflight.mjs",
    "preflight:cli-parity": "node scripts/run-pr-validation-preflight.mjs --step cli-parity",
    "typecheck": "nuxi typecheck",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "playwright test e2e/critical-flows/job-creation.spec.ts e2e/critical-flows/source-tracking.spec.ts",
    "test:e2e:uploads": "playwright test e2e/critical-flows/resume-upload.spec.ts",
    "test:e2e:security:core": "playwright test e2e/security/tenant-isolation.spec.ts --grep @security-core",
    "test:e2e:security:extended": "FEATURE_FLAG_CHATBOT_EXPERIENCE=true playwright test e2e/security/tenant-isolation.spec.ts --grep @security-extended",
    "test:e2e:ui": "playwright test e2e/critical-flows/invitation-management.spec.ts",
    "cli:pack": "npm pack --workspace @thefactory/careers-cli --dry-run",
    "cli:publish": "npm publish --workspace @thefactory/careers-cli",
    "ops:backup-restore-rehearsal": "bash scripts/backup-restore-rehearsal.sh",
    "ops:object-storage-restore-rehearsal": "bash scripts/object-storage-restore-rehearsal.sh",
    "ops:validate-production-env": "node scripts/validate-production-env.mjs",
    "i18n:crowdin:upload": "crowdin upload sources",
    "i18n:crowdin:download": "crowdin download --all",
    "i18n:crowdin:sync": "npm run i18n:crowdin:upload && npm run i18n:crowdin:download"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/xai": "^3.0.92",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@better-auth/sso": "^1.6.11",
    "@caffeinebounce/email": "^0.6.126",
    "@fontsource-variable/inter": "^5.2.8",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/mdc": "^0.22.0",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@posthog/nuxt": "^1.7.42",
    "@react-email/render": "^2.0.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "ai": "^6.0.191",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.1",
    "file-type": "^21.3.0",
    "googleapis": "^171.4.0",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.12.0",
    "nodemailer": "8.0.8",
    "nuxt": "^4.4.6",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "posthog-node": "^5.28.0",
    "resend": "^6.12.3",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4",
    "word-extractor": "^1.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.14.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.15",
    "commander": "^13.1.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "fast-xml-parser": "5.7.1",
    "samlify": "2.13.1",
    "brace-expansion": "5.0.6",
    "ws": "8.20.1",
    "nodemailer": "8.0.8",
    "qs": "6.15.2",
    "tar": "7.5.11",
    "minimatch": "10.2.5",
    "glob": "13.0.6",
    "@isaacs/brace-expansion": "5.0.1",
    "axios": "1.16.1",
    "@posthog/nuxt": {
      "@posthog/cli": "npm:empty-npm-package@1.0.0"
    },
    "readdir-glob": "2.0.2",
    "rollup": "4.60.1",
    "esbuild": "0.28.0",
    "serialize-javascript": "7.0.5",
    "underscore": "1.13.8",
    "h3": "1.15.11",
    "devalue": "5.8.1",
    "unhead": "2.1.13",
    "uuid": "14.0.0",
    "fast-xml-builder": "1.2.0",
    "kysely": "0.28.17",
    "simple-git": "3.36.0",
    "protobufjs": "8.3.0"
  }
}
